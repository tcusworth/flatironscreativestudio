            throw new Error('bad status');
          } catch (err) {
            btn.disabled = false; btn.textContent = 'Save my seat ↗';
            msg.textContent = 'Something went wrong — please try again, or email us and we\'ll register you manually.';
            msg.style.color = '#b3261e';
          }
        });
      </script>
