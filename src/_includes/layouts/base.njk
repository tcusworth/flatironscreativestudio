<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{{ title if title else "Flatirons Creative Studio — Boulder's senior digital studio" }}</title>
  <meta name="description" content="{{ description if description else 'A senior Boulder studio for websites, AI clarity, SEO, and custom software.' }}">
  <link rel="canonical" href="https://flatironscreativestudio.com{{ page.url }}">
  <link rel="icon" type="image/png" sizes="32x32" href="/assets/img/favicon-32.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/assets/img/apple-touch-icon.png">
  <meta property="og:type" content="website">
  <meta property="og:title" content="{{ title if title else 'Flatirons Creative Studio' }}">
  <meta property="og:description" content="{{ description if description else 'A senior Boulder studio for websites, AI clarity, SEO, and custom software.' }}">
  <meta property="og:url" content="https://flatironscreativestudio.com{{ page.url }}">
  <meta property="og:image" content="https://flatironscreativestudio.com/assets/img/og-image.png">
  <meta name="twitter:card" content="summary_large_image">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Poppins:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://assets.calendly.com/assets/external/widget.css">
  <script src="https://assets.calendly.com/assets/external/widget.js" async></script>
  <link rel="stylesheet" href="/assets/css/main.css">
</head>
<body class="{{ 'has-transparent-nav' if page.url == '/' else '' }}">

<nav class="nav" id="nav">
  <div class="nav-inner">
    <a href="/" class="nav-logo">
      <div class="nav-logo-mark">FCS</div>
      <span class="nav-logo-name">Flatirons <em>Creative Studio</em></span>
    </a>
    <div class="nav-links">
      <a href="/services/" {% if page.url == '/services/' %}class="active"{% endif %}>Services</a>
      <a href="/work/"     {% if page.url == '/work/'     %}class="active"{% endif %}>Work</a>
      <a href="/blog/"     {% if page.url == '/blog/'     %}class="active"{% endif %}>Blog</a>
      <a href="/about/"    {% if page.url == '/about/'    %}class="active"{% endif %}>About</a>
      <a href="/contact/"  {% if page.url == '/contact/'  %}class="active"{% endif %}>Contact</a>
    </div>
    <a href="/contact/" class="nav-cta">Start a Project ↗</a>
    <button class="nav-burger" id="navBurger" aria-label="Menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<div class="mobile-backdrop" id="mobileBackdrop"></div>
<nav class="mobile-sheet" id="mobileSheet">
  <button class="mobile-close" id="mobileClose" aria-label="Close">✕</button>
  <a href="/services/">Services</a>
  <a href="/work/">Work</a>
  <a href="/blog/">Blog</a>
  <a href="/about/">About</a>
  <a href="/contact/">Contact</a>
  <a href="/contact/" class="mobile-cta">Start a Project ↗</a>
</nav>

{{ content | safe }}

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <div class="footer-logo">Flatirons Creative Studio</div>
      <p>A senior Boulder studio building creative work that performs — brand, web, AI visibility, SEO, and custom software.</p>
      <div class="footer-contact">
        <a href="mailto:hello@flatironscreativestudio.com">hello@flatironscreativestudio.com</a>
        <span>Boulder, Colorado</span>
      </div>
    </div>
    <div class="footer-col">
      <h6>Services</h6>
      <ul>
        <li><a href="/services/">Web design &amp; build</a></li>
        <li><a href="/services/">AI Clarity Index</a></li>
        <li><a href="/services/">SEO retainer</a></li>
        <li><a href="/services/">AI productivity</a></li>
        <li><a href="/services/">Custom SaaS</a></li>
      </ul>
    </div>
    <div class="footer-col">
      <h6>Studio</h6>
      <ul>
        <li><a href="/work/">Work</a></li>
        <li><a href="/about/">About</a></li>
        <li><a href="/blog/">Blog</a></li>
        <li><a href="/contact/">Contact</a></li>
      </ul>
    </div>
    <div class="footer-col">
      <h6>Elsewhere</h6>
      <ul>
        <li><a href="https://aiclarityindex.com" target="_blank" rel="noopener">AI Clarity Index ↗</a></li>
        <li><a href="https://linkedin.com/in/trevorcusworth" target="_blank" rel="noopener">LinkedIn ↗</a></li>
        <li><a href="/privacy/">Privacy</a></li>
      </ul>
    </div>
  </div>
  <div class="footer-bar">
    <span>© 2026 Flatirons Creative Studio · Boulder, Colorado</span>
    <span>Built with intention.</span>
  </div>
</footer>

<script src="/assets/js/main.js"></script>
</body>
</html>
